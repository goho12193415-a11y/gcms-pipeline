        Items.Strings = (
          'Standard non-polar (e.g., DB-1, OV-101...) '
          'Semi-standard non-polar (e.g., DB-5, ZB-5, SE-52, and also squalane)'
          'Standard polar (e.g., DB-WAX, polyethylene glycol)'
          'Other (DB-624, OV-17, DB-1701, DB-210)'
        )
        OnChange = ColumnTypeComboBoxChange
        TabOrder = 0
