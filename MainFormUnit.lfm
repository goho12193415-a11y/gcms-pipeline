  OnCreate = FormCreate
  LCLVersion = '2.0.12.0'
  object Label9: TLabel
    Left = 0
    Height = 140
    Top = 248
    Width = 630
    AutoSize = False
    Caption = 'Do not forget to cite the following article if you are using this software in your research:  Matyushin, D. D.; Sholokhova, A. Yu.; Buryak, A. K. Deep learning based prediction of gas chromatographic retention indices for a wide variety of polar and mid-polar liquid stationary phases. Submitted to Anal. Chem., in press. '
    ParentColor = False
    WordWrap = True
  end
